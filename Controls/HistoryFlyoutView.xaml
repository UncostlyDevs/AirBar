<UserControl x:Class="FloatingTaskbarMenu.Controls.HistoryFlyoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FloatingTaskbarMenu.Controls"
             xmlns:models="clr-namespace:FloatingTaskbarMenu.Models"
             Width="340"
             MaxHeight="430">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
            <controls:ThemeIconView Kind="History"
                                    FallbackGlyph="&#xE81C;"
                                    IconSize="16"
                                    Foreground="{DynamicResource AccentBrush}"
                                    Margin="0,0,8,0"/>
            <TextBlock Text="Recently Closed"
                       FontSize="14"
                       FontWeight="SemiBold"
                       FontFamily="{DynamicResource AirBarDisplayFontFamily}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:WindowHistory}">
                        <Border Background="{DynamicResource MenuBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="{DynamicResource AirBarBorderThickness}"
                                CornerRadius="{DynamicResource AirBarInnerCornerRadius}"
                                Padding="10,7"
                                Margin="0,0,8,7"
                                MouseRightButtonUp="OnHistoryItemRightClick">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding ProcessName}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding ClosedTime, StringFormat='Closed: {0:g}'}"
                                           FontSize="9"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <Button Width="34"
                    Height="30"
                    DockPanel.Dock="Left"
                    Click="OnPreviousClick"
                    Style="{StaticResource MenuItemButtonStyle}">
                <controls:ThemeIconView Kind="Back"
                                        FallbackGlyph="&#xE76B;"
                                        IconSize="15"
                                        GlyphFontSize="14"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Button>
            <Button Width="34"
                    Height="30"
                    DockPanel.Dock="Right"
                    Click="OnNextClick"
                    Style="{StaticResource MenuItemButtonStyle}">
                <controls:ThemeIconView Kind="Next"
                                        FallbackGlyph="&#xE76C;"
                                        IconSize="15"
                                        GlyphFontSize="14"
                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Button>
            <TextBlock x:Name="PageIndicator"
                       Text="Page 1"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"/>
        </DockPanel>
    </Grid>
</UserControl>
