<UserControl x:Class="FloatingTaskbarMenu.Controls.WindowListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FloatingTaskbarMenu.Controls"
             xmlns:models="clr-namespace:FloatingTaskbarMenu.Models">

    <UserControl.Resources>
        <Style x:Key="WindowRowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource AirBarInnerCornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ItemHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ItemPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PinMarkerStyle" TargetType="{x:Type controls:ThemeIconView}">
            <Setter Property="Kind" Value="Pin"/>
            <Setter Property="FallbackGlyph" Value="&#xE718;"/>
            <Setter Property="IconSize" Value="12"/>
            <Setter Property="GlyphFontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ItemsControl x:Name="WindowList">
        <ItemsControl.ItemContainerStyle>
            <Style TargetType="ContentPresenter">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type models:WindowListEntry}">
                <Grid>
                    <Button x:Name="SingleWindowButton"
                            DataContext="{Binding Window}"
                            Style="{StaticResource WindowRowButtonStyle}"
                            Click="OnWindowClick"
                            MouseRightButtonUp="OnWindowRightClick"
                            ToolTipService.InitialShowDelay="400"
                            ToolTipService.ShowDuration="6000"
                            ToolTipService.BetweenShowDelay="100">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource Win11TooltipStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               FontSize="{DynamicResource AirBarBaseFontSize}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="260"/>
                                    <TextBlock Text="{Binding ProcessName}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </ToolTip>
                        </Button.ToolTip>
                        <DockPanel>
                            <controls:ThemeIconView Style="{StaticResource PinMarkerStyle}" DockPanel.Dock="Right"/>
                            <Image Source="{Binding Icon}"
                                   Width="20"
                                   Height="20"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding Title}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       FontSize="{DynamicResource AirBarBaseFontSize}"
                                       FontFamily="{DynamicResource AirBarFontFamily}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </DockPanel>
                    </Button>

                    <Expander x:Name="GroupExpander"
                              DataContext="{Binding Group}"
                              Visibility="Collapsed"
                              IsExpanded="False"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="8,4"
                              Margin="0,2"
                              Foreground="{DynamicResource TextSecondaryBrush}">
                        <Expander.Header>
                            <DockPanel>
                                <controls:ThemeIconView Style="{StaticResource PinMarkerStyle}" DockPanel.Dock="Right"/>
                                <Image Source="{Binding GroupIcon}"
                                       Width="16"
                                       Height="16"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding GroupName}"
                                           FontWeight="SemiBold"
                                           FontSize="{DynamicResource AirBarBaseFontSize}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding WindowCount, StringFormat=' ({0})'}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                            </DockPanel>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{Binding Windows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:WindowInfo}">
                                    <Button Style="{StaticResource WindowRowButtonStyle}"
                                            Click="OnWindowClick"
                                            MouseRightButtonUp="OnWindowRightClick"
                                            ToolTipService.InitialShowDelay="400"
                                            ToolTipService.ShowDuration="6000"
                                            ToolTipService.BetweenShowDelay="100">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource Win11TooltipStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="{DynamicResource AirBarBaseFontSize}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="260"/>
                                                    <TextBlock Text="{Binding ProcessName}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <DockPanel Margin="16,0,0,0">
                                            <controls:ThemeIconView Style="{StaticResource PinMarkerStyle}" DockPanel.Dock="Right"/>
                                            <Image Source="{Binding Icon}"
                                                   Width="20"
                                                   Height="20"
                                                   Margin="0,0,10,0"
                                                   VerticalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       FontSize="{DynamicResource AirBarBaseFontSize}"
                                                       FontFamily="{DynamicResource AirBarFontFamily}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </DockPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </Grid>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding IsGroup}" Value="True">
                        <Setter TargetName="SingleWindowButton" Property="Visibility" Value="Collapsed"/>
                        <Setter TargetName="GroupExpander" Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
