<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="AcrylicFallbackColor">#F3F3F3</Color>
    <Color x:Key="AcrylicFallbackColorDark">#202020</Color>
    <SolidColorBrush x:Key="AcrylicFallbackBrush" Color="{StaticResource AcrylicFallbackColor}"/>
    <SolidColorBrush x:Key="AcrylicFallbackBrushDark" Color="{StaticResource AcrylicFallbackColorDark}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5F5F5F"/>
    <SolidColorBrush x:Key="TextPrimaryBrushDark" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrushDark" Color="#A0A0A0"/>

    <SolidColorBrush x:Key="HoverBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="HoverBrushDark" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="PressedBrush" Color="#D5D5D5"/>
    <SolidColorBrush x:Key="PressedBrushDark" Color="#3D3D3D"/>

    <SolidColorBrush x:Key="AccentBrush" Color="#0067C0"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#005BB5"/>

    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="BorderBrushDark" Color="#3C3C3C"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="SeparatorBrushDark" Color="#3A3A3A"/>

    <SolidColorBrush x:Key="CloseHoverBrush" Color="#E81123"/>
    <SolidColorBrush x:Key="ClosePressedBrush" Color="#F1707A"/>

    <!-- Shadow Effect -->
    <DropShadowEffect x:Key="MenuShadow" BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.18" Color="#000000"/>

    <!-- Font -->
    <FontFamily x:Key="SegoeUIVariable">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>

    <!-- Window Style for Menu -->
    <Style x:Key="FloatingMenuWindowStyle" TargetType="Window">
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ResizeMode" Value="NoResize"/>
        <Setter Property="ShowInTaskbar" Value="False"/>
        <Setter Property="Topmost" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        <Setter Property="FontFamily" Value="{DynamicResource AirBarFontFamily}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- Menu Item Button -->
    <Style x:Key="MenuItemButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Window Item Button (for taskbar items) -->
    <Style x:Key="WindowItemButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuItemButtonStyle}">
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <!-- Icon Button (for system tray / aux icons) -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Context Menu Style -->
    <Style x:Key="Win11ContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource AcrylicFallbackBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="FontFamily" Value="{DynamicResource AirBarFontFamily}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Effect="{StaticResource MenuShadow}"
                            Padding="{TemplateBinding Padding}">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menu Item Style -->
    <Style x:Key="Win11MenuItemStyle" TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="12,6,20,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ScrollViewer Style -->
    <Style x:Key="Win11ScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <ScrollContentPresenter/>
                        <ScrollBar Name="PART_VerticalScrollBar"
                                   Orientation="Vertical"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Stretch"
                                   Width="8"
                                   Margin="0,4,2,4"
                                   Opacity="0.6"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separator Style -->
    <Style x:Key="Win11SeparatorStyle" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource SeparatorBrush}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="12,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Rectangle Fill="{TemplateBinding Background}"
                               Height="{TemplateBinding Height}"
                               Margin="{TemplateBinding Margin}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Preview Popup Style -->
    <Style x:Key="PreviewPopupStyle" TargetType="Popup">
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="PopupAnimation" Value="Fade"/>
        <Setter Property="Placement" Value="Right"/>
        <Setter Property="HorizontalOffset" Value="8"/>
    </Style>

</ResourceDictionary>
