<Window x:Class="FloatingTaskbarMenu.Windows.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input"
        Width="380"
        MinHeight="196"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource MenuBackgroundBrush}"
        FontFamily="{DynamicResource AirBarFontFamily}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText"
                   Grid.Row="0"
                   Text="Enter value:"
                   FontSize="14"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,12"
                   FontFamily="{DynamicResource AirBarFontFamily}"/>

        <TextBox x:Name="InputTextBox"
                 Grid.Row="1"
                 FontSize="12"
                 Padding="8"
                 Background="{DynamicResource HoverBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 BorderThickness="{DynamicResource AirBarBorderThickness}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 FontFamily="{DynamicResource AirBarFontFamily}"
                 ToolTip="Enter the value"
                 Margin="0,0,0,16"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="104" Height="40"
                    Padding="16,0"
                    Margin="0,0,10,0"
                    ToolTip="Confirm"
                    Click="OnOkClick"
                    Style="{StaticResource PrimaryMenuItemButtonStyle}"/>
            <Button Content="Cancel"
                    Width="104" Height="40"
                    Padding="16,0"
                    ToolTip="Cancel"
                    Click="OnCancelClick"
                    Style="{StaticResource MenuItemButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
