<Window x:Class="FloatingTaskbarMenu.Windows.ThemedMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinAirBar"
        Width="410"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        FontFamily="{DynamicResource AirBarFontFamily}"
        FontSize="{DynamicResource AirBarBaseFontSize}"
        KeyDown="OnKeyDown">
    <Border Margin="8"
            Background="{DynamicResource MenuBackgroundBrush}"
            BorderBrush="{DynamicResource MenuBorderBrush}"
            BorderThickness="{DynamicResource AirBarBorderThickness}"
            CornerRadius="{DynamicResource AirBarCornerRadius}">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="3" Opacity="0.38"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="{DynamicResource AirBarHeaderCornerRadius}"
                    Padding="14,10">
                <TextBlock x:Name="TitleText"
                           Foreground="{DynamicResource HeaderTextBrush}"
                           FontFamily="{DynamicResource AirBarDisplayFontFamily}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <Grid Grid.Row="1" Margin="16,14,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="IconBadge"
                        Width="28"
                        Height="28"
                        CornerRadius="{DynamicResource AirBarInnerCornerRadius}"
                        Background="{DynamicResource HoverBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Margin="0,1,12,0"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="IconText"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Column="1"
                              MaxHeight="220"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="MessageText"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{DynamicResource AirBarFontFamily}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource FooterBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="{DynamicResource AirBarFooterCornerRadius}"
                    Padding="14,12">
                <StackPanel x:Name="ButtonPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
